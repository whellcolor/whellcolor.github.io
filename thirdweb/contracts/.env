# =========================================
# SMART WALLET FULL SYSTEM
# =========================================

APP_NAME=SmartWalletFullSystem
APP_ENV=production
APP_VERSION=1.0.0

# =========================================
# NETWORK
# =========================================

CHAIN_ID=8453
NETWORK_NAME=Base
RPC_URL=https://mainnet.base.org

# =========================================
# OWNER WALLET
# =========================================

OWNER_WALLET=0x32ed98666663Fc8Dc7264BaF3fC1a3Ac4BFAE24B

# =========================================
# SMART WALLET
# =========================================

SMART_WALLET=0x7D4B0583DB9c1bb69F481e241DdAa5943Bad7763

# =========================================
# ACCOUNT FACTORY
# =========================================

ACCOUNT_FACTORY_V06=0x85e23b94e7F5E9cC1fF78BCe78cfb15B81f0DF00
ACCOUNT_FACTORY_V07=0x4be0ddfebca9a5a4a617dee4dece99e7c862dceb

ENTRYPOINT_V06=0.6
ENTRYPOINT_V07=0.7

# =========================================
# THIRDWEB
# =========================================

THIRDWEB_API_URL=https://api.thirdweb.com
THIRDWEB_SECRET_KEY=YOUR_SECRET_KEY
THIRDWEB_CLIENT_ID=YOUR_CLIENT_ID

# =========================================
# CLAIM
# =========================================

CLAIM_AMOUNT=0.9
CLAIM_TOKEN=ETH

# =========================================
# MINER
# =========================================

MINER_REWARD=0.9
MINER_ENABLED=true

# =========================================
# SWAP
# =========================================

SWAP_FROM=ETH
SWAP_TO=USDC
SWAP_AMOUNT=0.9

# =========================================
# MINT
# =========================================

MINT_ENABLED=true
MINT_TOKEN=NFT
MINT_AMOUNT=1

# =========================================
# FAUCET
# =========================================

FAUCET_ENABLED=true
FAUCET_AMOUNT=0.9

# =========================================
# DAPP
# =========================================

DAPP_NAME=SmartWalletEVM
DAPP_ENABLED=true

# =========================================
# LOG SYSTEM
# =========================================

LOG_ENABLED=true
LOG_LEVEL=debug

# =========================================
# SEND / RECEIVE
# =========================================

SEND_AMOUNT=0.9
SEND_TOKEN=ETH

RECEIVE_AMOUNT=0.9
RECEIVE_TOKEN=ETH

# =========================================
# SECURITY
# =========================================

ENABLE_AUTH=true
ENABLE_SIGNATURE=true
ENABLE_GASLESS=true

# =========================================
# GAS
# =========================================

MAX_GAS_LIMIT=500000
GAS_PRICE=auto

# =========================================
# CONTRACT
# =========================================

CONTRACT_NAME=SmartWalletFullSystem
CONTRACT_SYMBOL=SWFS
CONTRACT_VERSION=1.0

# =========================================
# API
# =========================================

API_PORT=3000
API_HOST=0.0.0.0

# =========================================
# FRONTEND
# =========================================

NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_NETWORK=Base
NEXT_PUBLIC_SMART_WALLET=0x7D4B0583DB9c1bb69F481e241DdAa5943Bad7763

# =========================================
# DEPLOYMENT
# =========================================

DEPLOYER_ADDRESS=0x32ed98666663Fc8Dc7264BaF3fC1a3Ac4BFAE24B
DEPLOY_NETWORK=base-mainnet

# =========================================
# ABI
# =========================================

ABI_FILE=SmartWalletFullSystem-ABI.json
CONTRACT_FILE=SmartWalletFullSystem.sol

# =========================================
# JSON FILES
# =========================================

MINER_JSON=miner.json
SWAP_JSON=swap.json
DAPP_JSON=dapp.json
MINT_JSON=mint.json
FAUCET_JSON=faucet.json
LOG_JSON=log.json
KEY_JSON=key.json
SEND_JSON=send.json
RECEIVED_JSON=received.json
